# Godot 4 .gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# .NET / C# build output
.godot/
bin/
obj/
*.user
*.suo
*.userprefs

# VS Code
.vscode/
*.code-workspace

# JetBrains Rider
.idea/
*.sln
*.csproj.user

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini
